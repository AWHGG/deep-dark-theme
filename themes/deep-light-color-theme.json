    "tokenColors": [
        {
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#757575",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "keyword",
                "keyword.control",
                "keyword.operator.new",
                "storage",
                "storage.type",
                "storage.modifier"
            ],
            "settings": {
                "foreground": "#AF00DB"
            }
        },
        {
            "scope": [
                "constant",
                "constant.numeric",
                "constant.language"
            ],
            "settings": {
                "foreground": "#0000FF"
            }
        },
        {
            "scope": [
                "string",
                "string.quoted"
            ],
            "settings": {
                "foreground": "#108510"
            }
        },
        {
            "scope": [
                "variable",
                "variable.other",
                "variable.language",
                "variable.parameter"
            ],
            "settings": {
                "foreground": "#24292E"
            }
        },
        {
            "scope": [
                "entity.name.function",
                "support.function"
            ],
            "settings": {
                "foreground": "#005FB8"
            }
        },
        {
            "scope": [
                "support.class",
                "support.type",
                "entity.name.class",
                "entity.name.type.class",
                "entity.name.type",
                "entity.other.inherited-class"
            ],
            "settings": {
                "foreground": "#A31515"
            }
        },
        {
            "scope": [
                "entity.name.tag",
                "meta.tag.sgml",
                "markup.deleted.git_gutter"
            ],
            "settings": {
                "foreground": "#E53935"
            }
        },
        {
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#795E26"
            }
        },
        {
            "scope": [
                "punctuation",
                "meta.brace",
                "keyword.operator"
            ],
            "settings": {
                "foreground": "#333333"
            }
        },
        {
            "scope": [
                "text.html.markdown",
                "meta.embedded.block.markdown",
                "markup.content",
                "source.chat",
                "meta.paragraph.markdown"
            ],
            "settings": {
                "foreground": "#24292E"
            }
        },
        {
            "scope": [
                "markup.heading"
            ],
            "settings": {
                "foreground": "#005FB8",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.bold"
            ],
            "settings": {
                "fontStyle": "bold",
                "foreground": "#24292E"
            }
        },
        {
            "scope": [
                "markup.quote"
            ],
            "settings": {
                "foreground": "#757575",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "markup.raw",
                "markup.inline.raw"
            ],
            "settings": {
                "foreground": "#108510"
            }
        }
    ]
}
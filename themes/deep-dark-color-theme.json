    "tokenColors": [
        {
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#767ea0",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "keyword",
                "keyword.control",
                "keyword.operator.new"
            ],
            "settings": {
                "foreground": "#9779cc"
            }
        },
        {
            "scope": [
                "storage",
                "storage.type",
                "storage.modifier"
            ],
            "settings": {
                "foreground": "#9779cc"
            }
        },
        {
            "scope": [
                "constant",
                "constant.numeric",
                "constant.language"
            ],
            "settings": {
                "foreground": "#ef9864"
            }
        },
        {
            "scope": [
                "string",
                "string.quoted"
            ],
            "settings": {
                "foreground": "#98c369"
            }
        },
        {
            "scope": [
                "variable",
                "variable.other",
                "variable.language"
            ],
            "settings": {
                "foreground": "#a2a9ca"
            }
        },
        {
            "scope": [
                "variable.parameter"
            ],
            "settings": {
                "foreground": "#d3a767"
            }
        },
        {
            "scope": [
                "entity.name.function",
                "support.function"
            ],
            "settings": {
                "foreground": "#779be8"
            }
        },
        {
            "scope": [
                "support.class",
                "support.type"
            ],
            "settings": {
                "foreground": "#15b0cb"
            }
        },
        {
            "scope": [
                "entity.name.class",
                "entity.name.type.class"
            ],
            "settings": {
                "foreground": "#2fb9d1"
            }
        },
        {
            "scope": [
                "entity.name.type",
                "entity.other.inherited-class"
            ],
            "settings": {
                "foreground": "#2fb9d1"
            }
        },
        {
            "scope": [
                "entity.name.tag",
                "meta.tag.sgml",
                "markup.deleted.git_gutter"
            ],
            "settings": {
                "foreground": "#e87489"
            }
        },
        {
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#b294e8"
            }
        },
        {
            "scope": [
                "punctuation",
                "meta.brace"
            ],
            "settings": {
                "foreground": "#94b4e6"
            }
        },
        {
            "scope": [
                "keyword.operator"
            ],
            "settings": {
                "foreground": "#85d0ef"
            }
        },
        {
            "scope": [
                "text.html.markdown",
                "meta.embedded.block.markdown",
                "markup.content",
                "source.chat"
            ],
            "settings": {
                "foreground": "#bbbbbb"
            }
        },
        {
            "scope": "markup.quote",
            "settings": {
                "foreground": "#c2c2c2",
                "fontStyle": "italic"
            }
        },
        {
            "scope": "markup.raw",
            "settings": {
                "foreground": "#bbbbbb"
            }
        }
    ]
}